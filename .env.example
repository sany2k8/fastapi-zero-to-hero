# Copy to .env and adjust. Every value here maps to a field in app/core/config.py.

# --- Application ---
ENVIRONMENT=development            # development | staging | production | test
DEBUG=true
APP_NAME="TaskHub API"

# --- Database ---
# Local dev default is SQLite; docker-compose overrides with Postgres.
DATABASE_URL=sqlite+aiosqlite:///./taskhub.db
# DATABASE_URL=postgresql+asyncpg://taskhub:taskhub@localhost:5432/taskhub
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_ECHO=false

# --- Auth ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=dev-only-secret-key-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS / hosts ---
CORS_ORIGINS=["http://localhost:3000"]
ALLOWED_HOSTS=["*"]

# --- Rate limiting ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
LOGIN_RATE_LIMIT_REQUESTS=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60

# --- Uploads ---
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_BYTES=5242880

# --- Logging ---
LOG_LEVEL=INFO
LOG_JSON=false                     # true in production for machine-readable logs
